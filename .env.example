# =============================================================================
# 공유 환경 변수
#
# 로드 대상:
#   - backend/config.py        (uvicorn 바인드, Origin 가드, 각종 상수)
#   - frontend/vite.config.js  (dev 프록시 타겟)
#
# 이 파일은 dev 와 frozen EXE 양쪽에서 로드된다. frozen EXE 는 App.spec datas 로
# MEIPASS 에 임베드된 .env 를 읽는다 (OS 환경 변수가 있으면 그쪽 우선).
# 주석 처리된 항목은 기본값을 나타낸다. 변경이 필요한 항목만 주석을 해제한다.
# =============================================================================


# -----------------------------------------------------------------------------
# 네트워크 (frontend 와 공유)
#
# 호스트는 루프백(127.0.0.1)으로 코드에 고정 — env 미노출 (외부 네트워크 노출 방지).
# frozen EXE 는 APP_PORT 또는 APP_NAME 해시(47100–48999) 기반 고정 포트를 쓴다.
# 고정 포트로 localStorage origin 이 실행마다 일정해 대화 기록이 재기동 후에도 보존된다.
# 같은 포트가 점유 중이면 +1..+4 후보 체인으로 폴백한다.
# APP_PORT=0 이면 구 동작(OS 동적 할당)으로 돌아간다 — 대화 기록이 실행마다 격리됨.
#
# dev 는 Vite(5173)→백엔드 프록시 타겟이 사전 합의돼야 하므로 dev 백엔드 포트만 별도 노출.
# 기본 8765, 충돌 시에만 주석 해제해 변경 (config.py + vite.config.js 가 함께 읽음).
# -----------------------------------------------------------------------------
# APP_PORT=47381     # SenPIA 해시 기본값. 명시하면 hash 계산을 건너뜀. 0이면 동적.
# APP_DEV_PORT=8765


# -----------------------------------------------------------------------------
# browser / watchdog
# -----------------------------------------------------------------------------
APP_STARTUP_GRACE=60             # 첫 presence 연결까지 기다리는 상한 (초)
APP_SHUTDOWN_GRACE=2             # 마지막 클라이언트 사라진 후 종료까지 대기 (초)
APP_PRESENCE_RECONNECT_GRACE=2   # F5 / 네트워크 블립 흡수 재연결 허용 시간 (초)
APP_PRESENCE_KEEPALIVE_INTERVAL=30  # SSE ping 코멘트 전송 주기 (초)
APP_PRESENCE_RETRY_HINT_MS=1000  # EventSource retry 디렉티브 (ms)


# -----------------------------------------------------------------------------
# update / 원격 저장소 (GitHub Enterprise Releases)
#
# APP_REPO_BASE_URL : GHE 레포 루트. 예) https://github.mycompany.com/org/repo
#                     updater 가 여기서 REST API base(.../api/v3) 와 owner/repo 를 유도한다.
#                     private 레포 에셋은 브라우저 다운로드 URL 이 PAT 헤더를 무시하고 404 를
#                     주므로, 메타·EXE 모두 REST API(releases/latest + assets/{id})로 받는다.
#                     최신 릴리즈는 full release(비-prerelease)만 잡히므로 QA 빌드는 제외된다.
# APP_REPO_READ_TOKEN : 읽기 전용 Classic PAT (private 레포용, scope: repo).
#                     EXE 에 번들되어 릴리즈 메타 / EXE 다운로드 인증에 사용된다.
#                     업로드용 쓰기 토큰은 gh CLI 가 담당하므로 소스 .env 에 두지 않는다
#                     (App.spec 이 빌드 .env 에서 필터링).
# APP_BUILD_CHANNEL : EXE 빌드 채널. App.spec 이 release.ps1 -Channel 값을 주입하므로
#                     소스 .env 에 설정하지 않는다(개발자가 실수로 고정하는 것을 방지).
# APP_REPO_TLS_VERIFY : 기본 true. 사내 CA 가 certifi 에 없어 SSLError 가 나면 false.
#                     Windows 에서는 시스템 인증서 저장소를 자동으로 사용하므로
#                     인증서 관리자가 CA 를 Windows 에 추가하면 이 옵션이 불필요하다.
# -----------------------------------------------------------------------------
APP_REPO_BASE_URL="https://<ghe-host>/<org>/<repo>"
APP_REPO_READ_TOKEN=""           # GHE read-only Classic PAT (scope: repo), EXE 에 번들됨
# APP_GH_REPO=<org>/<repo>       # gh release create --repo 옵션. git origin 과 같으면 생략 가능.
# APP_REPO_TLS_VERIFY=false      # 사내 CA 가 certifi 에 없을 때 false 설정 (Windows 는 자동)
APP_UPDATE_CHECK_TIMEOUT=5       # 릴리즈 메타 GET 타임아웃 (초)
APP_UPDATE_DOWNLOAD_TIMEOUT=60   # EXE 다운로드 타임아웃 (초)
APP_UPDATE_CHECK_CACHE_TTL=300   # /api/update/check 캐시 유효 시간 (초)


# -----------------------------------------------------------------------------
# 콘텐츠 동기화 (SKILLS/AGENTS/PROMPTS 런타임 갱신)
#
# frozen EXE 가 기동 시 매핑된 GitHub 브랜치에서 마크다운을 가져와 EXE 재빌드 없이
# 콘텐츠를 갱신한다. 채널→브랜치: qa→dev, prod→main. 어떤 실패도 번들 콘텐츠로 폴백.
# APP_REPO_BASE_URL / APP_REPO_READ_TOKEN 을 updater 와 공유한다(같은 PAT, scope: repo).
#
# APP_CONTENT_SYNC_ENABLED : 기본 frozen=true, dev=false. dev 는 로컬 워킹트리 + 핫리로드
#                     를 유지하므로 동기화하지 않는다. false 로 frozen 에서도 강제 차단 가능.
# APP_CONTENT_SYNC_BRANCH : 채널 매핑을 무시하고 이 브랜치를 직접 본다(카나리 검증용).
#                     빈 값이면 채널 매핑(qa→dev, prod→main) 사용.
# -----------------------------------------------------------------------------
# APP_CONTENT_SYNC_ENABLED=false   # frozen 에서 콘텐츠 동기화를 끄려면 false
# APP_CONTENT_SYNC_BRANCH=dev      # 채널 매핑 대신 특정 브랜치 강제(카나리)
APP_CONTENT_SYNC_TIMEOUT=5         # 기동 시 동기화 블로킹 상한 (초)


# -----------------------------------------------------------------------------
# LLM / Agent
# -----------------------------------------------------------------------------
APP_NAME="SENPIA"

# 초기 설정 시드 (settings.json 이 없을 때만 적용; 이후엔 settings.json 이 우선)
APP_LLM_PROVIDER="dtgpt"
APP_DTGPT_BASE_URL="http://cloud.dtgpt.samsungds.net/llm/v1"
APP_DTGPT_MODEL="standard"

# 생성 파라미터 (settings.json 미사용, 환경 변수로만 제어)
APP_LLM_TEMPERATURE=0.7          # 0.0 ~ 2.0
# APP_LLM_MAX_TOKENS=              # 미설정 시 provider 기본값 사용

# 에이전트 동작
APP_MAX_AGENT_ITERATIONS=12      # 한 턴당 provider→tool→provider 반복 상한 (복합 시나리오 E 오케스트레이터: tool 5턴 + 최종 종합 1턴 = 6 필요, headroom 8)
APP_MAX_AGENT_CALLS_PER_TURN=20  # 오케스트레이터+서브 에이전트 합산 provider 호출 상한 (TurnBudget). 2단 위임 복합 작업 ≒ 14회
APP_MAX_HISTORY_MESSAGES=40      # 클라이언트당 보관 메시지 수 상한 (system 제외)

# 기타
APP_SETTINGS_TEST_TIMEOUT=10     # 연결 테스트 타임아웃 (초)

# 디버그 (dev 전용 — frozen EXE 는 이 값과 무관하게 항상 비활성)
APP_DEBUG_TRACE=true             # 턴마다 provider wire in/out + 하니스 결정점을 result/<session>/_trace/<turn>.jsonl 에 기록
                                 # TopBar 패널 런처 → Tracer 확장에서 타임라인 조회


# -----------------------------------------------------------------------------
# 라이브러리 런타임 (Library Runtime)
# -----------------------------------------------------------------------------
# ▼ 화이트리스트 CSV: polars,spade 형식 (backend/scripts 패키지 + polars 노출)
APP_ALLOWED_LIBRARIES=scripts,numpy,polars,pandas
APP_NAMESPACE_MEMORY_THRESHOLD=10485760  # 세션 변수 in-memory 한계 (bytes, 기본 10MB)
APP_NAMESPACE_MAX_VARS=20         # 세션당 변수 최대 개수 (LRU 강등 한도)

# ▼ 오케스트레이터 baseline api_refs (CSV) — SKILL/서브에이전트 없이도 오케스트레이터가
#   상시 docstring 을 인지할 라이브러리 dotted-path 목록. 빈 값(기본)이면 기존 동작과
#   100% 동일(활성 SKILL 의 api_refs 가 있을 때만 '# Available Library APIs' 노출).
#   런타임 메타 도구(call_function 등)는 원래 오케스트레이터에 항상 노출돼 있으므로,
#   이 변수가 추가로 주는 것은 '무슨 함수가 있는지'를 알려주는 prompt 섹션이다.
#   잘못된 경로는 경고 후 skip 되어 어떤 값이어도 부팅/턴이 깨지지 않는다.
# APP_ORCHESTRATOR_API_REFS="scripts.stats_df.compute_summary_stats_df"
