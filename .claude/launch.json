{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "backend/main.py"],
      "port": 8765
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173
    },
    {
      "name": "evaluator",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "extensions/evaluator/frontend", "run", "dev"],
      "port": 5174
    },
    {
      "name": "slides",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["--yes", "http-server", "docs/overview/slides", "-p", "4599", "-c-1"],
      "port": 4599
    }
  ]
}
