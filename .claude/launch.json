{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "backend",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "backend/main.py"],
      "port": 8765,
      "autoPort": false
    },
    {
      "name": "frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev"],
      "port": 5173
    },
    {
      "name": "evaluator",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "extensions/evaluator/frontend", "run", "dev"],
      "port": 5174
    },
    {
      "name": "tracer",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "extensions/tracer/frontend", "run", "dev"],
      "port": 5175
    },
    {
      "name": "backend-flow-docs",
      "runtimeExecutable": "uv",
      "runtimeArgs": ["run", "python", "-m", "http.server", "8900", "--directory", "docs/overview/backend-flow"],
      "port": 8900,
      "autoPort": false
    }
  ]
}
