# Shared between backend and frontend.
# Loaded by:
#   - backend/config.py    (uvicorn bind + Origin guard)
#   - frontend/vite.config.js  (dev proxy target)
#
# Only active in dev mode. The packaged EXE uses defaults baked into config.py.
APP_HOST=127.0.0.1
APP_PORT=8765

# Nexus raw repository base URL for update distribution.
# Used by: backend/updater.py, scripts/release.ps1
# Uncomment to override the in-code default.
# APP_NEXUS_BASE_URL=https://nexus.internal/repository/myagent
