# =============================================================================
# 공유 환경 변수
#
# 로드 대상:
#   - backend/config.py        (uvicorn 바인드, Origin 가드, 각종 상수)
#   - frontend/vite.config.js  (dev 프록시 타겟)
#
# dev 모드 전용. 패키징된 EXE 는 config.py 의 기본값을 사용한다.
# 주석 처리된 항목은 기본값을 나타낸다. 변경이 필요한 항목만 주석을 해제한다.
# =============================================================================


# -----------------------------------------------------------------------------
# 네트워크 (frontend 와 공유)
# -----------------------------------------------------------------------------
APP_HOST=127.0.0.1
APP_PORT=8765


# -----------------------------------------------------------------------------
# browser / watchdog
# -----------------------------------------------------------------------------
APP_STARTUP_GRACE=60             # 첫 presence 연결까지 기다리는 상한 (초)
APP_SHUTDOWN_GRACE=2             # 마지막 클라이언트 사라진 후 종료까지 대기 (초)
APP_PRESENCE_RECONNECT_GRACE=2   # F5 / 네트워크 블립 흡수 재연결 허용 시간 (초)
APP_PRESENCE_KEEPALIVE_INTERVAL=30  # SSE ping 코멘트 전송 주기 (초)
APP_PRESENCE_RETRY_HINT_MS=1000  # EventSource retry 디렉티브 (ms)


# -----------------------------------------------------------------------------
# update / nexus
# -----------------------------------------------------------------------------
# APP_NEXUS_BASE_URL=https://nexus.internal/repository/app
APP_UPDATE_CHECK_TIMEOUT=5       # latest.json GET 타임아웃 (초)
APP_UPDATE_DOWNLOAD_TIMEOUT=60   # EXE 다운로드 타임아웃 (초)
APP_UPDATE_CHECK_CACHE_TTL=300   # /api/update/check 캐시 유효 시간 (초)


# -----------------------------------------------------------------------------
# LLM / Agent
# -----------------------------------------------------------------------------
APP_NAME=MyAgent                 # 앱 이름 — settings.json 경로 및 EXE 파일명에 사용

초기 설정 시드 (settings.json 이 없을 때만 적용; 이후엔 settings.json 이 우선)
APP_LLM_PROVIDER=mock            # mock | openai_compatible
# APP_LLM_BASE_URL=                # OpenAI 호환 엔드포인트 (예: http://localhost:11434/v1)
# APP_LLM_MODEL=                   # 모델명 (예: gpt-4o)
# APP_LLM_API_KEY=                 # API 키 (보안 주의 — .gitignore 확인)

생성 파라미터 (settings.json 미사용, 환경 변수로만 제어)
APP_SYSTEM_PROMPT=You are a helpful AI agent. 한국어 사용자에게는 한국어로 친절히 답한다. 필요하면 등록된 도구를 사용해 정확한 정보를 제공한다.
APP_LLM_TEMPERATURE=0.7          # 0.0 ~ 2.0
# APP_LLM_MAX_TOKENS=              # 미설정 시 provider 기본값 사용

에이전트 동작
APP_MAX_AGENT_ITERATIONS=5       # 한 턴당 provider→tool→provider 반복 상한
APP_MAX_HISTORY_MESSAGES=40      # 클라이언트당 보관 메시지 수 상한 (system 제외)

기타
APP_SETTINGS_TEST_TIMEOUT=10     # 연결 테스트 타임아웃 (초)
